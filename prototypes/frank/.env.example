# Copy this file to .env in this directory and fill in your own keys.
# .env is gitignored; only .env.example is committed.

# Example: OpenAI
# OPENAI_API_KEY=

# Example: Anthropic
# ANTHROPIC_API_KEY=

# Example: generic provider base URL + key (adjust names to your stack)
# AI_API_BASE_URL=
# AI_API_KEY=
