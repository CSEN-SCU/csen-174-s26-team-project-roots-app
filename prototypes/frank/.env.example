# Copy to .env in this folder (gitignored). Never commit real secrets.

# Required: place extraction from reel captions (JSON structured output)
OPENAI_API_KEY=

# Optional: override model (default gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Optional: API port when using `python -m app.main` (uvicorn in app uses this via Settings)
# PORT=8787

# Optional: tighten or loosen how far from the trip anchor a POI may sit (km)
# (defaults are in app/config.py if unset)
# MAX_PLACE_RADIUS_KM=75
# AVG_URBAN_SPEED_KMH=18
