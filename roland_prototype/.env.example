# ─── Required ────────────────────────────────────────────────────────────────
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── Optional ─────────────────────────────────────────────────────────────────
# Instagram Graph API token — only needed if you want to fetch real Instagram
# Reel captions/descriptions. Without it, Instagram URLs still work but Claude
# synthesizes a plan from the URL path alone.
# Get one at https://developers.facebook.com/docs/instagram-basic-display-api
INSTAGRAM_ACCESS_TOKEN=

# YouTube Data API v3 key — enriches YouTube extraction with video descriptions.
# Without it, YouTube oEmbed still gives title + creator name for free.
# Get one at https://console.cloud.google.com/ → APIs → YouTube Data API v3
YOUTUBE_API_KEY=
